  "keyFeatures": [
    "Institutional news carousel with dynamic content",
    "Health guide with establishments, services, and strategies",
    "Public access to regulatory documents and resolutions",
    "Role-based admin dashboard (admin and editor roles)",
    "JWT authentication with automatic token refresh",
    "Offline mode with session persistence",
    "File-based routing with Expo Router",
    "Secure credential storage with expo-secure-store"
  ],
  "publicApiSurface": [
    "useAuth() - Authentication hook with signIn/signOut",
    "useDebounce() - Debounce hook for search inputs",
    "useThemeColor() - Theme-aware color hook",
    "useFetchNormas() - Hook for fetching regulatory documents",
    "apiClient - Configured Axios instance with interceptors",
    "setAuthToken() - Set JWT token for API requests",
    "getStoredToken() - Retrieve stored authentication token",
    "AuthProvider - Context provider for authentication state",
    "PermissionContext - Context for role-based permissions",
    "ThemedText - Theme-aware text component",
    "ThemedView - Theme-aware view component"
  ]
}
